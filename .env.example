# ============================================================
# 环境变量
# 复制为 .env 并填写实际值
# ============================================================

# 数据库连接串（PostgreSQL）
# 若使用项目自带的 docker-compose 一键数据库，直接用下面这行即可（凭据已与 docker-compose.yml 对齐）
DATABASE_URL=postgresql+asyncpg://postgres:softbei_demo@localhost:5432/softbei

# 数据库密码（与 docker-compose.yml 中 POSTGRES_PASSWORD 一致）
DB_PASSWORD=softbei_demo

# LLM API 密钥（本项目测试专用密钥）
LLM_API_KEY=sk-ws-H.EMERMLP.i7t6.MEYCIQDCIPFnbawMlIlANc3uxUzjergjU8Thi7CQat-m2OrjJwIhAOEnaiIFplmd_5X0KDknQ9dgGqWdgpS86xedNzZiiGQR

# JWT 密钥（生产环境务必使用随机字符串）
JWT_SECRET=your_jwt_secret_here_change_in_production

# ============================================================
# SMTP 邮件服务配置
# 不配置则使用 debug 模式（邮件保存到本地 debug_emails/ 目录）
# QQ邮箱: SMTP_HOST=smtp.qq.com SMTP_PORT=587
# 163邮箱: SMTP_HOST=smtp.163.com SMTP_PORT=465
# Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=587
# ============================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_TIMEOUT=30
EMAIL_MAX_RETRIES=3
EMAIL_VERIFY_EXPIRE_MINUTES=30
EMAIL_PASSWORD_RESET_EXPIRE_MINUTES=15
EMAIL_RATE_LIMIT_PER_HOUR=5

# Tavily 搜索 API Key（视频搜索备选源，可选）
TAVILY_API_KEY=
